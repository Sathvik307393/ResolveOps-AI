# --- AWS & Amazon Bedrock Configuration ---
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.meta.llama4-maverick-17b-instruct-v1:0

# --- SMTP / Email Notification Configuration ---
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
NEXUS_SENDER_EMAIL=your-email@example.com

# --- Proxy Configuration for Kubernetes / External Services ---
# Set these if your AWS EC2 instance needs to connect to the AKS API server via a proxy or bastion.
# K8S_PROXY_URL=http://your-proxy-server:port
# HTTPS_PROXY=http://your-proxy-server:port
# HTTP_PROXY=http://your-proxy-server:port
